{
  "name": "@ractysh/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "dev": "tsx watch src/server.ts",
    "prebuild": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "build": "tsc",
    "start": "node dist/server.js",
    "pretypecheck": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema ../../packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../packages/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ../../packages/db/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema ../../packages/db/prisma/schema.prisma",
    "prisma:verify": "tsx prisma/verify.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@ractysh/shared": "*",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "resend": "^6.12.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
